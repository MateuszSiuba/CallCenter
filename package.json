{
  "name": "callcenter",
  "private": true,
  "version": "0.1.0",
  "description": "CallCenter Support Hub monorepo",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "start": "node backend/src/server.js",
    "start:backend": "npm --prefix backend start",
    "dev:backend": "npm --prefix backend run dev",
    "dev": "vite",
    "build": "vite build",
    "regen-models": "node ./scripts/regenerate_public_models.js",
    "import:postgres": "npm --prefix backend run import:postgres",
    "quick:test": "node ./scripts/quick_test.js",
    "load:test": "node ./scripts/load_test_search.js"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14"
  }
}
